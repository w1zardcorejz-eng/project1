<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
  <defs>
    <radialGradient id="bg" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#1a1a2e"/>
      <stop offset="100%" stop-color="#0a0a15"/>
    </radialGradient>
    <linearGradient id="lotus" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#a78bfa"/>
      <stop offset="50%" stop-color="#8b5cf6"/>
      <stop offset="100%" stop-color="#fbbf24"/>
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="2" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>

  <circle cx="50" cy="50" r="50" fill="url(#bg)"/>

  <g filter="url(#glow)">
    <!-- Outer petals -->
    <ellipse cx="50" cy="58" rx="10" ry="30" fill="url(#lotus)" opacity="0.6" transform="rotate(0 50 58)"/>
    <ellipse cx="50" cy="58" rx="10" ry="30" fill="url(#lotus)" opacity="0.6" transform="rotate(45 50 58)"/>
    <ellipse cx="50" cy="58" rx="10" ry="30" fill="url(#lotus)" opacity="0.6" transform="rotate(90 50 58)"/>
    <ellipse cx="50" cy="58" rx="10" ry="30" fill="url(#lotus)" opacity="0.6" transform="rotate(135 50 58)"/>
    <ellipse cx="50" cy="58" rx="10" ry="30" fill="url(#lotus)" opacity="0.6" transform="rotate(180 50 58)"/>
    <ellipse cx="50" cy="58" rx="10" ry="30" fill="url(#lotus)" opacity="0.6" transform="rotate(225 50 58)"/>
    <ellipse cx="50" cy="58" rx="10" ry="30" fill="url(#lotus)" opacity="0.6" transform="rotate(270 50 58)"/>
    <ellipse cx="50" cy="58" rx="10" ry="30" fill="url(#lotus)" opacity="0.6" transform="rotate(315 50 58)"/>

    <!-- Inner petals -->
    <ellipse cx="50" cy="55" rx="6" ry="20" fill="#a78bfa" opacity="0.9" transform="rotate(22.5 50 55)"/>
    <ellipse cx="50" cy="55" rx="6" ry="20" fill="#a78bfa" opacity="0.9" transform="rotate(67.5 50 55)"/>
    <ellipse cx="50" cy="55" rx="6" ry="20" fill="#a78bfa" opacity="0.9" transform="rotate(112.5 50 55)"/>
    <ellipse cx="50" cy="55" rx="6" ry="20" fill="#a78bfa" opacity="0.9" transform="rotate(157.5 50 55)"/>
    <ellipse cx="50" cy="55" rx="6" ry="20" fill="#a78bfa" opacity="0.9" transform="rotate(202.5 50 55)"/>
    <ellipse cx="50" cy="55" rx="6" ry="20" fill="#a78bfa" opacity="0.9" transform="rotate(247.5 50 55)"/>
    <ellipse cx="50" cy="55" rx="6" ry="20" fill="#a78bfa" opacity="0.9" transform="rotate(292.5 50 55)"/>
    <ellipse cx="50" cy="55" rx="6" ry="20" fill="#a78bfa" opacity="0.9" transform="rotate(337.5 50 55)"/>

    <!-- Center -->
    <circle cx="50" cy="48" r="8" fill="#fbbf24" opacity="0.8"/>
  </g>

  <!-- Glow effect -->
  <circle cx="50" cy="45" r="20" fill="none" stroke="#a78bfa" stroke-width="1" opacity="0.3" filter="url(#glow)"/>
</svg>
